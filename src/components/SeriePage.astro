---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

interface Props {
  name: string;
  description: string;
  price: string;
  folder: string;
  features: string[];
  colorImages: string[];
  slug: string;
}

const { name, description, price, folder, features, colorImages, slug } = Astro.props;

const imagesDir = `/images/cocinas/${folder}`;
const images = colorImages
  .map((img) => (img.startsWith('/') ? img : `${imagesDir}/catalogo/${img}`))
  .filter((img) => !img.includes('undefined'));

const siteUrl = "https://masmoebel.es";

const breadcrumbsSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Cocinas", "item": siteUrl + "/cocinas" },
    { "@type": "ListItem", "position": 3, "name": name, "item": siteUrl + `/cocinas/${slug}` },
  ],
};
---

<Layout title={`${name} - MasMöbel`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbsSchema)} />
  <Header />

  <main class="min-h-screen">
    <section class="pt-20 pb-6 bg-gradient-to-br from-[#1A1A1A] via-[#2a2a2a] to-[#1A1A1A] text-center px-4 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-10 left-10 w-32 h-32 bg-[#8B7355] rounded-full blur-3xl"></div>
        <div class="absolute bottom-10 right-10 w-48 h-48 bg-[#8B7355] rounded-full blur-3xl"></div>
      </div>
      <div class="relative z-10 max-w-4xl mx-auto">
        <h1 class="text-2xl md:text-3xl font-bold text-white mb-2">{name}</h1>
        <p class="text-sm text-gray-300">{description}</p>
        <p class="text-lg text-[#8B7355] mt-1 font-semibold">{price}</p>
      </div>
    </section>

    <section class="py-6 bg-white px-4">
      <div style="max-width: 1280px; margin: 0 auto; padding: 0 1rem;">
        <h2 class="text-lg font-bold text-center text-[#1A1A1A] mb-4">Colores y acabados</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
          {images.map((img, index) => (
            <div class="relative overflow-hidden rounded-xl shadow-lg hover:shadow-xl transition-shadow">
              <img
                src={img}
                alt={`${name} - Color ${index + 1}`}
                class="w-full aspect-square object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-6 bg-[#F5F5F5] px-4">
      <div style="max-width: 1280px; margin: 0 auto; padding: 0 1rem;">
        <h2 class="text-lg font-bold text-center text-[#1A1A1A] mb-4">Características</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          {features.map((feature) => (
            <div class="flex items-center gap-3 p-4 bg-white rounded-xl shadow-sm">
              <div class="w-10 h-10 bg-[#8B7355] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-[#1A1A1A] font-medium">{feature}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-4 bg-[#1A1A1A] text-center px-4">
      <div style="max-width: 1280px; margin: 0 auto; padding: 0 1rem;">
        <h2 class="text-xl font-bold text-white mb-2">¿Te gusta esta serie?</h2>
        <p class="text-sm text-gray-400 mb-4">Solicita un presupuesto personalizado</p>
        <a href="/contacto" class="inline-block px-6 py-3 bg-[#8B7355] text-white text-base rounded-lg hover:bg-[#6d5a43] transition-colors">Solicitar presupuesto</a>
      </div>
    </section>

    <section class="py-6 bg-white text-center px-4">
      <div style="max-width: 1280px; margin: 0 auto; padding: 0 1rem;">
        <a href="/cocinas" class="text-sm text-[#8B7355] hover:underline transition-colors">← Volver a todas las cocinas</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>