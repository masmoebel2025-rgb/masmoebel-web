---
---

<section class="py-10 bg-[#1A1A1A]">
	<div class="max-w-md mx-auto px-6 text-center">
		<h2 class="text-lg font-bold text-white mb-2">¿Listo para tu proyecto?</h2>
		<p class="text-xs text-gray-400 mb-4">Solicita tu presupuesto sin compromiso</p>
		<form class="space-y-3" name="presupuesto" method="POST" data-netlify="true">
			<input type="text" name="name" placeholder="Tu nombre" required class="w-full px-3 py-2 bg-white/10 border border-white/20 rounded text-white text-sm placeholder-gray-400 focus:outline-none focus:border-[#8B7355]" />
			<input type="email" name="email" placeholder="Email" required class="w-full px-3 py-2 bg-white/10 border border-white/20 rounded text-white text-sm placeholder-gray-400 focus:outline-none focus:border-[#8B7355]" />
			<input type="tel" name="phone" placeholder="Teléfono" class="w-full px-3 py-2 bg-white/10 border border-white/20 rounded text-white text-sm placeholder-gray-400 focus:outline-none focus:border-[#8B7355]" />
			<button type="submit" class="w-full py-2 bg-[#8B7355] text-white text-sm font-medium rounded hover:bg-[#6d5a43]">Enviar</button>
		</form>
		<p class="mt-3 text-xs text-gray-500"><a href="/privacidad" class="underline">Política de privacidad</a></p>
	</div>
</section>