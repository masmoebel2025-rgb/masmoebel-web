---
interface Props {
	name: string;
	price?: string;
	imageUrl: string;
	category?: string;
	href?: string;
}

const { name, price, imageUrl, category, href } = Astro.props;
---

<article class="group cursor-pointer">
	<a href={href || '#'} class="block">
		<div class="overflow-hidden rounded-lg" style="aspect-ratio: 1/1;">
			<img
				src={imageUrl}
				alt={name}
				class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
				loading="lazy"
				decoding="async"
			/>
		</div>
		<div class="mt-3 transition-colors duration-300">
			{category && (
				<span class="text-xs text-[#8B7355]">{category}</span>
			)}
			<h3 class="text-sm font-medium text-[#1A1A1A] group-hover:text-[#8B7355] transition-colors duration-300">{name}</h3>
			{price && (
				<p class="text-sm text-[#8B7355]">{price}</p>
			)}
		</div>
	</a>
</article>
