---
interface Props {
	title: string;
	description: string;
	href: string;
	imageUrl: string;
}

const { title, description, href, imageUrl } = Astro.props;
---

<a href={href} class="group block">
	<div class="relative overflow-hidden rounded-lg transition-all duration-500 group-hover:shadow-xl" style="aspect-ratio: 16/10;">
		<img
			src={imageUrl}
			alt={title}
			class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
		/>
		<div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent transition-opacity duration-500 group-hover:from-black/70"></div>
		<div class="absolute bottom-0 left-0 right-0 p-5 transition-transform duration-500 group-hover:-translate-y-1">
			<h3 class="text-base font-semibold text-white group-hover:scale-105 transition-transform duration-300">{title}</h3>
			<p class="text-sm text-gray-200 mt-1">{description}</p>
		</div>
	</div>
</a>
