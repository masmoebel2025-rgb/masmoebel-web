---
const navItems = [
	{ href: '/', label: 'Inicio' },
	{ href: '/cocinas', label: 'Cocinas' },
	{ href: '/experiencias', label: 'Experiencias' },
	{ href: '/nosotros', label: 'Nosotros' },
	{ href: '/contacto', label: 'Contacto' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-orange-200 shadow-sm">
	<div style="max-width: 1280px; margin: 0 auto; padding: 0 2rem;">
		<nav>
			<div class="flex items-center justify-between h-16">
				<a href="/" class="text-2xl font-bold tracking-tight text-gray-900">
					mas<span class="text-orange-600">moebel</span>
				</a>
				<div class="hidden md:flex items-center justify-center gap-8 flex-1">
					{navItems.map((item) => (
						<a href={item.href} class="text-sm font-medium text-gray-700 hover:text-orange-600 transition-colors duration-200">{item.label}</a>
					))}
				</div>
				<div class="hidden md:block w-20"></div>
				<button id="mobile-menu-btn" class="md:hidden p-2 text-gray-700" aria-label="Menú">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
					</svg>
				</button>
			</div>
			<div id="mobile-menu" class="hidden md:hidden pb-4">
				{navItems.map((item) => (
					<a href={item.href} class="block py-2 text-sm text-gray-700 hover:text-orange-600 transition-colors duration-200">{item.label}</a>
				))}
			</div>
		</nav>
	</div>
</header>

<script>
	const btn = document.getElementById('mobile-menu-btn');
	const menu = document.getElementById('mobile-menu');
	btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
