---
const year = new Date().getFullYear();
---

<footer class="text-white py-16" style="background: linear-gradient(180deg, rgba(249, 115, 22, 0.95) 0%, rgba(239, 68, 68, 0.95) 100%);">
	<div style="max-width: 1280px; margin: 0 auto; padding: 0 1rem;">
		<div class="grid grid-cols-2 md:grid-cols-4 gap-10 text-sm">
			<div>
				<span class="text-2xl font-bold tracking-tight">mas<span class="font-black">moebel</span></span>
				<p class="mt-3 text-orange-100 text-sm">Muebles Domínguez García 2.0 SL</p>
			</div>
			<div>
				<h4 class="font-semibold text-sm text-orange-100 mb-4 uppercase tracking-wider">Navegación</h4>
				<ul class="space-y-2.5">
					<li><a href="/" class="text-white/80 hover:text-white transition-colors duration-200">Inicio</a></li>
					<li><a href="/cocinas" class="text-white/80 hover:text-white transition-colors duration-200">Cocinas</a></li>
					<li><a href="/nosotros" class="text-white/80 hover:text-white transition-colors duration-200">Nosotros</a></li>
					<li><a href="/blog" class="text-white/80 hover:text-white transition-colors duration-200">Blog</a></li>
