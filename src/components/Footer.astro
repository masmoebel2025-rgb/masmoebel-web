---
const year = new Date().getFullYear();
---

<footer class="text-white py-16" style="background: linear-gradient(180deg, var(--color-primary) 0%, #0C0A09 100%);">
	<div style="max-width: 1280px; margin: 0 auto; padding: 0 1rem;">
		<div class="grid grid-cols-2 md:grid-cols-4 gap-10 text-sm">
			<div>
				<span class="text-2xl font-bold tracking-tight" style="font-family: var(--font-heading);">mas<span style="color: var(--color-cta);">moebel</span></span>
				<p class="mt-3 text-stone-400 text-sm">Muebles Domínguez García 2.0 SL</p>
			</div>
			<div>
				<h4 class="font-semibold text-sm text-stone-400 mb-4 uppercase tracking-wider">Navegación</h4>
				<ul class="space-y-2.5">
					<li><a href="/" class="text-stone-300 hover:text-white transition-colors duration-200">Inicio</a></li>
					<li><a href="/cocinas" class="text-stone-300 hover:text-white transition-colors duration-200">Cocinas</a></li>
					<li><a href="/nosotros" class="text-stone-300 hover:text-white transition-colors duration-200">Nosotros</a></li>
					<li><a href="/contacto" class="text-stone-300 hover:text-white transition-colors duration-200">Contacto</a></li>
				</ul>
			</div>
			<div>
				<h4 class="font-semibold text-sm text-stone-400 mb-4 uppercase tracking-wider">Legal</h4>
				<ul class="space-y-2.5 text-stone-300 text-sm">
					<li><a href="/aviso-legal" class="hover:text-white transition-colors duration-200">Aviso Legal</a></li>
					<li><a href="/privacidad" class="hover:text-white transition-colors duration-200">Privacidad</a></li>
					<li><a href="/cookies" class="hover:text-white transition-colors duration-200">Cookies</a></li>
				</ul>
			</div>
			<div>
				<h4 class="font-semibold text-sm text-stone-400 mb-4 uppercase tracking-wider">Contacto</h4>
				<ul class="space-y-2.5 text-stone-300 text-sm">
					<li>+34 692 68 61 48</li>
					<li>info@masmoebel.es</li>
					<li>Plaza Cruces de Mayo 3<br/>21830 Bonares, Huelva</li>
				</ul>
			</div>
		</div>

		<div class="mt-12 pt-8 border-t border-stone-800 text-center text-sm text-stone-500">
			<p>© 2026-{year} Muebles Domínguez García 2.0 SL</p>
		</div>
	</div>
</footer>
