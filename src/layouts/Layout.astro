---
import '../styles/global.css';
import ChatWidget from '../components/ChatWidget.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';
import StickyBudgetButton from '../components/StickyBudgetButton.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const {
	title,
	description = "MasMöbel - Cocinas y muebles a medida en Huelva. Diseño, fabricación e instalación. Presupuesto sin compromiso.",
	image = "/images/og-image.svg"
} = Astro.props;

const siteUrl = "https://masmoebel.es";
const currentUrl = new URL(Astro.url.pathname, siteUrl);
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content="index, follow" />

		<!-- Open Graph -->
		<meta property="og:title" content={`${title} | MasMöbel`} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={currentUrl} />
		<meta property="og:image" content={image} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content="MasMöbel" />
		<meta property="og:locale" content="es_ES" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={`${title} | MasMöbel`} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		<!-- Schema.org LocalBusiness -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "FurnitureStore",
			"name": "MasMöbel - Muebles Domínguez García",
			"description": "Cocinas y muebles a medida de alta calidad",
			"url": siteUrl,
			"telephone": "+34623229653",
			"email": "info@masmoebel.es",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "Plaza Cruces de Mayo 3",
				"addressLocality": "Bonares",
				"addressRegion": "Huelva",
				"postalCode": "21830",
				"addressCountry": "ES"
			},
			"geo": {
				"@type": "GeoCoordinates",
				"latitude": 37.3036,
				"longitude": -6.7384
			},
			"openingHoursSpecification": [
				{
					"@type": "OpeningHoursSpecification",
					"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
					"opens": "09:00",
					"closes": "18:00"
				},
				{
					"@type": "OpeningHoursSpecification",
					"dayOfWeek": ["Saturday", "Sunday"],
					"opens": "10:00",
					"closes": "14:00"
				}
			],
			"priceRange": "€€€",
			"image": siteUrl + "/images/og-image.svg",
			"sameAs": []
		})} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
		<title>{title} | MasMöbel</title>
		<slot name="head" />
	</head>
	<body>
		<slot />
		<ChatWidget />
		<ScrollAnimations />
		<StickyBudgetButton />
	</body>
</html>