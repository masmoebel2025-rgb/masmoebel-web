---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Sobre Nosotros - MasMöbel">
	<Header />

	<main>
		<!-- Hero -->
		<section class="pt-20 pb-16 text-center px-4 relative overflow-hidden" style="background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-primary-light) 100%);">
			<div class="absolute inset-0 opacity-5">
				<div class="absolute top-0 left-1/4 w-96 h-96 bg-white rounded-full blur-3xl -translate-y-1/2"></div>
				<div class="absolute bottom-0 right-1/4 w-64 h-64 bg-white rounded-full blur-3xl translate-y-1/2"></div>
			</div>
			<div class="relative z-10 max-w-3xl mx-auto">
				<h1 class="text-4xl md:text-5xl font-bold text-white mb-4" style="font-family: var(--font-heading);">Sobre Nosotros</h1>
				<p class="text-lg text-stone-300">Diseñamos cocinas únicas para hogares especiales</p>
			</div>
		</section>

		<!-- Historia -->
		<section class="py-20 bg-white px-4">
			<div style="max-width: 1200px; margin: 0 auto;">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div>
						<span class="text-sm font-semibold uppercase tracking-wider gold-accent mb-4 block">Nuestra Historia</span>
						<h2 class="text-3xl md:text-4xl font-bold mb-6" style="font-family: var(--font-heading); color: var(--color-text);">Tres generaciones de tradición y innovación</h2>
						<p class="text-base leading-relaxed mb-6" style="color: var(--color-text-muted);">Fundada en Bonares, Huelva, Muebles Domínguez García nació con una visión clara: crear mobiliario de alta calidad que combinara funcionalidad, estética y durabilidad. A lo largo de los años, hemos evolucionado adaptándonos a las tendencias y necesidades de nuestros clientes, pero manteniendo siempre nuestros valores fundamentales.</p>
						<p class="text-base leading-relaxed" style="color: var(--color-text-muted);">Hoy, como Muebles Domínguez García 2.0 SL, continuamos innovando y expandiendo nuestras líneas de productos, incorporando nuevas tecnologías y materiales sostenibles sin comprometer nuestra esencia.</p>
					</div>
					<div class="relative">
						<img src="/images/nosotros/factory.svg" alt="Fábrica" class="w-full rounded-lg" style="box-shadow: 0 20px 60px rgba(0,0,0,0.15);" />
					</div>
				</div>
			</div>
		</section>

		<!-- Valores -->
		<section class="py-20 px-4" style="background: var(--color-background);">
			<div style="max-width: 1200px; margin: 0 auto;">
				<h2 class="text-2xl font-bold text-center mb-12" style="font-family: var(--font-heading); color: var(--color-text);">Nuestros Valores</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="card p-8 text-center">
						<div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-6" style="background: linear-gradient(135deg, var(--color-cta), #EAB308);">
							<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l6.682-6.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
							</svg>
						</div>
						<h3 class="text-lg font-semibold mb-3" style="color: var(--color-text);">Pasión</h3>
						<p class="text-sm" style="color: var(--color-text-muted);">Cada proyecto lo abordamos con entusiasmo y dedicación.</p>
					</div>
					<div class="card p-8 text-center">
						<div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-6" style="background: linear-gradient(135deg, var(--color-cta), #EAB308);">
							<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
							</svg>
						</div>
						<h3 class="text-lg font-semibold mb-3" style="color: var(--color-text);">Calidad</h3>
						<p class="text-sm" style="color: var(--color-text-muted);">Materiales premium y acabados impecables. Garantía de 5 años.</p>
					</div>
					<div class="card p-8 text-center">
						<div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-6" style="background: linear-gradient(135deg, var(--color-cta), #EAB308);">
							<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
							</svg>
						</div>
						<h3 class="text-lg font-semibold mb-3" style="color: var(--color-text);">Personas</h3>
						<p class="text-sm" style="color: var(--color-text-muted);">Escuchamos, asesoramos y acompañamos a cada cliente.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Stats -->
		<section class="py-16 px-4" style="background: var(--color-primary);">
			<div style="max-width: 1000px; margin: 0 auto;">
				<div class="grid grid-cols-2 md:grid-cols-3 gap-8 text-center text-white">
					<div>
						<span class="text-4xl md:text-5xl font-bold gold-accent block mb-2">300+</span>
						<span class="text-sm text-stone-300">Proyectos</span>
					</div>
					<div>
						<span class="text-4xl md:text-5xl font-bold gold-accent block mb-2">100%</span>
						<span class="text-sm text-stone-300">España</span>
					</div>
					<div>
						<span class="text-4xl md:text-5xl font-bold gold-accent block mb-2">24h</span>
						<span class="text-sm text-stone-300">Respuesta</span>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>