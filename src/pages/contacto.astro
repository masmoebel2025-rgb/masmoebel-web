---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contacto - MasMöbel">
	<Header />

	<main>
		<!-- Hero Section -->
		<section class="relative h-[80vh] flex items-center justify-center overflow-hidden bg-gradient-to-br from-orange-500 via-red-500 to-orange-600">
			<div class="absolute inset-0">
				<div class="absolute top-0 left-0 w-96 h-96 bg-white/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
				<div class="absolute bottom-0 right-0 w-96 h-96 bg-white/10 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>
			</div>

			<div class="relative z-10 text-center px-4 sm:px-8 max-w-3xl mx-auto">
				<h1 class="text-5xl sm:text-6xl md:text-7xl font-bold text-white mb-6 tracking-tight">
					Hablemos de tu <span class="font-black">proyecto</span>
				</h1>
				<p class="text-xl md:text-2xl text-orange-50 max-w-2xl mx-auto font-light mb-8">
					Cuéntanos tu visión y crearemos la cocina de tus sueños
				</p>
				<a href="#formulario" class="inline-block px-8 py-4 bg-white text-orange-600 font-semibold rounded-lg hover:bg-orange-50 transition-all hover:shadow-lg hover:scale-105">
					Enviar Mensaje
				</a>
			</div>
		</section>

		<!-- Contact Info Cards -->
		<section class="py-20 bg-white">
			<div style="max-width: 1280px; margin: 0 auto; padding: 0 2rem;">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
					<!-- Teléfono -->
					<div class="bg-gradient-to-br from-orange-50 to-red-50 p-8 rounded-xl border border-orange-100 hover:border-orange-300 transition-all hover:shadow-lg">
						<div class="w-12 h-12 bg-gradient-to-br from-orange-500 to-red-500 rounded-full flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
							</svg>
						</div>
						<h3 class="text-lg font-semibold text-gray-900 mb-2">Teléfono</h3>
						<p class="text-orange-600 font-medium">+34 692 68 61 48</p>
						<p class="text-sm text-gray-600 mt-2">Llamanos de lunes a viernes</p>
					</div>

					<!-- Email -->
					<div class="bg-gradient-to-br from-orange-50 to-red-50 p-8 rounded-xl border border-orange-100 hover:border-orange-300 transition-all hover:shadow-lg">
						<div class="w-12 h-12 bg-gradient-to-br from-orange-500 to-red-500 rounded-full flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
							</svg>
						</div>
						<h3 class="text-lg font-semibold text-gray-900 mb-2">Email</h3>
						<p class="text-orange-600 font-medium">info@masmoebel.es</p>
						<p class="text-sm text-gray-600 mt-2">Responderemos rápidamente</p>
					</div>

					<!-- Dirección -->
					<div class="bg-gradient-to-br from-orange-50 to-red-50 p-8 rounded-xl border border-orange-100 hover:border-orange-300 transition-all hover:shadow-lg">
						<div class="w-12 h-12 bg-gradient-to-br from-orange-500 to-red-500 rounded-full flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
							</svg>
						</div>
						<h3 class="text-lg font-semibold text-gray-900 mb-2">Ubicación</h3>
						<p class="text-sm text-gray-700 font-medium">Plaza Cruces de Mayo 3<br/>21830 Bonares, Huelva</p>
					</div>

					<!-- Horario -->
					<div class="bg-gradient-to-br from-orange-50 to-red-50 p-8 rounded-xl border border-orange-100 hover:border-orange-300 transition-all hover:shadow-lg">
						<div class="w-12 h-12 bg-gradient-to-br from-orange-500 to-red-500 rounded-full flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
							</svg>
						</div>
						<h3 class="text-lg font-semibold text-gray-900 mb-2">Horario</h3>
						<p class="text-sm text-gray-700 font-medium">Lunes - Viernes<br/>9:00 - 18:00</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Contact Form Section -->
		<section id="formulario" class="py-20 bg-gray-50">
			<div style="max-width: 600px; margin: 0 auto; padding: 0 2rem;">
				<div class="text-center mb-12">
					<h2 class="text-4xl font-bold text-gray-900 mb-4">Envíanos tu proyecto</h2>
					<p class="text-lg text-gray-600">Completa el formulario y nos pondremos en contacto contigo lo antes posible</p>
				</div>

				<div class="bg-white rounded-2xl shadow-xl p-8 md:p-10">
					<form id="contact-form" name="contacto" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="space-y-6" novalidate>
						<input type="hidden" name="form-name" value="contacto" />
						<p hidden>
							<label>No filled this: <input name="bot-field" /></label>
						</p>

						<!-- Nombre -->
						<div>
							<label for="name" class="block text-sm font-semibold text-gray-900 mb-2">Nombre completo *</label>
							<input
								type="text"
								id="name"
								name="name"
								placeholder="Tu nombre"
								required
								minlength="2"
								class="w-full px-4 py-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 transition-all"
							/>
							<p id="name-error" class="text-red-500 text-xs mt-1 hidden">Por favor, introduce tu nombre</p>
						</div>

						<!-- Email -->
						<div>
							<label for="email" class="block text-sm font-semibold text-gray-900 mb-2">Email *</label>
							<input
								type="email"
								id="email"
								name="email"
								placeholder="tu@email.com"
								required
								class="w-full px-4 py-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 transition-all"
							/>
							<p id="email-error" class="text-red-500 text-xs mt-1 hidden">Introduce un email válido</p>
						</div>

						<!-- Teléfono -->
						<div>
							<label for="phone" class="block text-sm font-semibold text-gray-900 mb-2">Teléfono</label>
							<input
								type="tel"
								id="phone"
								name="phone"
								placeholder="+34 600 000 000"
								pattern="[\+]?[0-9\s]{9,15}"
								class="w-full px-4 py-3 border border-gray-300 rounded-lg text-base focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 transition-all"
							/>
							<p id="phone-error" class="text-red-500 text-xs mt-1 hidden">Teléfono no válido</p>
						</div>

						<!-- Mensaje -->
						<div>
							<label for="message" class="block text-sm font-semibold text-gray-900 mb-2">Cuéntanos sobre tu proyecto *</label>
							<textarea
								id="message"
								name="message"
								rows="5"
								placeholder="Describe tu proyecto, estilo, presupuesto, etc..."
								required
								minlength="10"
								class="w-full px-4 py-3 border border-gray-300 rounded-lg text-base resize-none focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 transition-all"
							></textarea>
							<p id="message-error" class="text-red-500 text-xs mt-1 hidden">Mínimo 10 caracteres</p>
						</div>

						<!-- Archivos -->
						<div>
							<label class="block text-sm font-semibold text-gray-900 mb-2">Adjuntar imágenes o documentos (opcional)</label>
							<div id="file-drop-zone" class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-orange-500 hover:bg-orange-50 transition-all cursor-pointer">
								<input
									type="file"
									id="files"
									name="files"
									multiple
									accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.zip,.rar"
									class="hidden"
								/>
								<div id="file-placeholder">
									<svg class="w-10 h-10 mx-auto text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
									</svg>
									<p class="text-sm text-gray-600 font-medium">Haz clic o arrastra archivos</p>
									<p class="text-xs text-gray-500 mt-1">PDF, DOC, JPG, PNG (máx. 5MB cada uno)</p>
								</div>
							</div>
							<div id="file-list" class="mt-3 space-y-2"></div>
							<p id="files-error" class="text-red-500 text-xs mt-1 hidden">Error en los archivos</p>
						</div>

						<!-- Submit Button -->
						<button
							type="submit"
							id="submit-btn"
							class="w-full py-4 bg-gradient-to-r from-orange-500 to-red-500 text-white font-semibold rounded-lg hover:shadow-lg hover:scale-[1.02] transition-all flex items-center justify-center gap-2"
						>
							<span id="btn-text">Enviar Mensaje</span>
							<svg id="btn-spinner" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
								<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
								<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
							</svg>
						</button>

						<!-- Success message -->
						<div id="success-message" class="hidden p-4 bg-green-50 border border-green-200 rounded-lg text-center">
							<svg class="w-12 h-12 mx-auto text-green-500 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
							</svg>
							<h3 class="font-semibold text-green-800">¡Mensaje enviado!</h3>
							<p class="text-sm text-green-600 mt-1">Te responderemos lo antes posible.</p>
						</div>
					</form>
				</div>

			</div>
		</section>

		<!-- Map Section -->
		<section class="py-16 bg-white">
			<div style="max-width: 1280px; margin: 0 auto; padding: 0 2rem;">
				<h2 class="text-3xl font-bold text-gray-900 text-center mb-10">Nuestra ubicación</h2>
				<div class="rounded-xl overflow-hidden shadow-lg">
					<iframe
						src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3190.7548738984843!2d-6.738475923465478!3d37.30363793469282!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd0dc4a6e6e8b8f9%3A0x0!2sPlaza%20Cruces%20de%20Mayo%2C%203%2C%2021830%20Bonares%2C%20Huelva!5e0!3m2!1ses!2ses!4v1704067200000"
						width="100%"
						height="450"
						style="border:0;"
						allowfullscreen
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
					></iframe>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<script>
	const MAX_FILE_SIZE = 5 * 1024 * 1024;
	const MAX_FILES = 5;
	const ALLOWED_TYPES = ['application/pdf', 'application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document', 'image/jpeg', 'image/png', 'application/zip', 'application/x-rar-compressed'];
	const ALLOWED_EXTENSIONS = ['.pdf', '.doc', '.docx', '.jpg', '.jpeg', '.png', '.zip', '.rar'];

	let selectedFiles = [];

	document.addEventListener('DOMContentLoaded', () => {
		const form = document.getElementById('contact-form');
		const submitBtn = document.getElementById('submit-btn');
		const btnText = document.getElementById('btn-text');
		const btnSpinner = document.getElementById('btn-spinner');
		const successMessage = document.getElementById('success-message');
		const fileInput = document.getElementById('files');
		const dropZone = document.getElementById('file-drop-zone');
		const fileList = document.getElementById('file-list');
		const filePlaceholder = document.getElementById('file-placeholder');

		const showError = (id, show) => {
			const el = document.getElementById(id);
			if (el) el.classList.toggle('hidden', !show);
		};

		function handleFiles(files) {
			if (!files) return;

			const newFiles = Array.from(files);
			const totalFiles = selectedFiles.length + newFiles.length;

			if (totalFiles > MAX_FILES) {
				showError('files-error', `Máximo ${MAX_FILES} archivos permitidos`);
				return;
			}

			for (const file of newFiles) {
				if (file.size > MAX_FILE_SIZE) {
					showError('files-error', `${file.name} excede 5MB`);
					return;
				}

				const ext = '.' + file.name.split('.').pop()?.toLowerCase();
				if (!ALLOWED_EXTENSIONS.includes(ext)) {
					showError('files-error', `${ext} no es un tipo permitido`);
					return;
				}

				selectedFiles.push(file);
			}

			showError('files-error', false);
			updateFileList();
		}

		function updateFileList() {
			fileList.innerHTML = '';
			if (selectedFiles.length === 0) {
				filePlaceholder.classList.remove('hidden');
			} else {
				filePlaceholder.classList.add('hidden');
			}

			selectedFiles.forEach((file, index) => {
				const div = document.createElement('div');
				div.className = 'flex items-center justify-between bg-orange-50 px-3 py-2 rounded-lg text-sm border border-orange-200';
				div.innerHTML = `
					<span class="truncate max-w-[200px] text-gray-700">${file.name}</span>
					<span class="text-gray-500 text-xs ml-2">${(file.size / 1024 / 1024).toFixed(2)} MB</span>
					<button type="button" class="ml-2 text-red-500 hover:text-red-700 remove-file" data-index="${index}">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
						</svg>
					</button>
				`;
				fileList.appendChild(div);
			});

			document.querySelectorAll('.remove-file').forEach(btn => {
				btn.addEventListener('click', (e) => {
					const index = parseInt(e.currentTarget.dataset.index || '0');
					selectedFiles.splice(index, 1);
					updateFileList();
				});
			});
		}

		dropZone.addEventListener('click', () => fileInput.click());
		fileInput.addEventListener('change', () => handleFiles(fileInput.files));

		dropZone.addEventListener('dragover', (e) => {
			e.preventDefault();
			dropZone.classList.add('border-orange-500', 'bg-orange-50');
		});

		dropZone.addEventListener('dragleave', () => {
			dropZone.classList.remove('border-orange-500', 'bg-orange-50');
		});

		dropZone.addEventListener('drop', (e) => {
			e.preventDefault();
			dropZone.classList.remove('border-orange-500', 'bg-orange-50');
			handleFiles(e.dataTransfer?.files || null);
		});

		const validateName = (value) => value.trim().length >= 2;
		const validateEmail = (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
		const validatePhone = (value) => !value || /^[\+]?[0-9\s]{9,15}$/.test(value.replace(/\s/g, ''));
		const validateMessage = (value) => value.trim().length >= 10;
		const validateFiles = () => {
			if (selectedFiles.length > MAX_FILES) return false;
			if (selectedFiles.some(f => f.size > MAX_FILE_SIZE)) return false;
			return true;
		};

		const fields = ['name', 'email', 'phone', 'message'];
		fields.forEach(fieldId => {
			const input = document.getElementById(fieldId);
			if (input) {
				input.addEventListener('blur', () => validateField(fieldId));
				input.addEventListener('input', () => {
					if (input.classList.contains('border-red-400')) {
						validateField(fieldId);
					}
				});
			}
		});

		function validateField(fieldId) {
			const input = document.getElementById(fieldId);
			if (!input) return true;

			let isValid = true;
			const value = input.value;

			switch (fieldId) {
				case 'name':
					isValid = validateName(value);
					showError('name-error', !isValid);
					break;
				case 'email':
					isValid = validateEmail(value);
					showError('email-error', !isValid);
					break;
				case 'phone':
					if (value) {
						isValid = validatePhone(value);
						showError('phone-error', !isValid);
					}
					break;
				case 'message':
					isValid = validateMessage(value);
					showError('message-error', !isValid);
					break;
			}

			input.classList.toggle('border-red-400', !isValid);
			input.classList.toggle('border-gray-300', isValid);
			return isValid;
		}

		function validateAll() {
			let isValid = true;
			fields.forEach(fieldId => {
				if (!validateField(fieldId)) isValid = false;
			});
			if (!validateFiles()) isValid = false;
			return isValid;
		}

		form.addEventListener('submit', async (e) => {
			e.preventDefault();

			if (!validateAll()) {
				return;
			}

			submitBtn.disabled = true;
			btnText.textContent = 'Enviando...';
			btnSpinner.classList.remove('hidden');

			const formData = new FormData(form);

			try {
				const response = await fetch('/', {
					method: 'POST',
					headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
					body: new URLSearchParams(formData).toString()
				});

				if (response.ok) {
					form.reset();
					selectedFiles = [];
					updateFileList();
					successMessage.classList.remove('hidden');
					submitBtn.classList.add('hidden');

					setTimeout(() => {
						successMessage.classList.add('hidden');
						submitBtn.classList.remove('hidden');
						submitBtn.disabled = false;
						btnText.textContent = 'Enviar Mensaje';
					}, 5000);
				} else {
					throw new Error('Network response not ok');
				}
			} catch (error) {
				submitBtn.disabled = false;
				btnText.textContent = 'Enviar Mensaje';
				btnSpinner.classList.add('hidden');
				showError('files-error', 'Error al enviar. Intenta nuevamente.');
			}
		});
	});
</script>
