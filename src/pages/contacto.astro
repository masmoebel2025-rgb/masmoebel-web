---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const phone = "+34692686148";
const whatsappUrl = `https://wa.me/${phone.replace('+', '')}`;
const whatsappMsg = encodeURIComponent("Hola, he enviado un mensaje desde la web y gustaría que me contactaran.");
---

<Layout title="Contacto - MasMöbel">
	<Header />

	<main>
		<section class="pt-20 pb-12 bg-gradient-to-br from-[#1A1A1A] via-[#2a2a2a] to-[#1A1A1A] text-center px-4 sm:px-8 relative overflow-hidden">
			<div class="absolute inset-0 opacity-10">
				<div class="absolute top-10 left-10 w-32 h-32 bg-[#8B7355] rounded-full blur-3xl"></div>
				<div class="absolute bottom-10 right-10 w-48 h-48 bg-[#8B7355] rounded-full blur-3xl"></div>
			</div>
			<div class="relative z-10 max-w-4xl mx-auto">
				<h1 class="text-3xl md:text-4xl font-bold text-white mb-3">Contacta con nosotros</h1>
				<p class="text-base text-gray-300">Estamos aquí para ayudarte a crear tu cocina ideal</p>
			</div>
		</section>

		<section class="py-16 bg-white px-4 sm:px-8">
			<div class="container">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
					<!-- Info -->
					<div>
						<h2 class="text-xl font-bold text-[#1A1A1A] mb-6">Habla con nosotros</h2>

						<div class="space-y-6">
							<div class="flex items-start gap-4 p-4 bg-[#F5F5F5] rounded-xl">
								<div class="w-12 h-12 bg-[#8B7355] rounded-full flex items-center justify-center flex-shrink-0">
									<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
									</svg>
								</div>
								<div>
									<h3 class="text-sm font-semibold text-[#1A1A1A]">Teléfono</h3>
									<p class="text-base text-[#8B7355]">+34 692 68 61 48</p>
								</div>
							</div>

							<div class="flex items-start gap-4 p-4 bg-[#F5F5F5] rounded-xl">
								<div class="w-12 h-12 bg-[#8B7355] rounded-full flex items-center justify-center flex-shrink-0">
									<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
									</svg>
								</div>
								<div>
									<h3 class="text-sm font-semibold text-[#1A1A1A]">Email</h3>
									<p class="text-base text-[#8B7355]">info@masmoebel.es</p>
								</div>
							</div>

							<div class="flex items-start gap-4 p-4 bg-[#F5F5F5] rounded-xl">
								<div class="w-12 h-12 bg-[#8B7355] rounded-full flex items-center justify-center flex-shrink-0">
									<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
									</svg>
								</div>
								<div>
									<h3 class="text-sm font-semibold text-[#1A1A1A]">Dirección</h3>
									<p class="text-base text-[#8B7355]">Plaza Cruces de Mayo 3, 21830 Bonares, Huelva</p>
								</div>
							</div>

							<div class="flex items-start gap-4 p-4 bg-[#F5F5F5] rounded-xl">
								<div class="w-12 h-12 bg-[#8B7355] rounded-full flex items-center justify-center flex-shrink-0">
									<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
									</svg>
								</div>
								<div>
									<h3 class="text-sm font-semibold text-[#1A1A1A]">Horario</h3>
									<p class="text-base text-[#8B7355]">Lunes a viernes, 9:00 - 18:00</p>
								</div>
							</div>
						</div>

						<!-- WhatsApp CTA -->
						<div class="mt-8">
							<a
								href={whatsappUrl}
								target="_blank"
								rel="noopener noreferrer"
								class="flex items-center justify-center gap-3 px-6 py-4 bg-[#25D366] text-white font-semibold rounded-full hover:bg-[#20bd5a] transition-all hover:scale-105 shadow-lg"
							>
								<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
									<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
								</svg>
								<span>Contactar por WhatsApp</span>
							</a>
						</div>
					</div>

					<!-- Form -->
					<div class="bg-gradient-to-br from-[#F5F5F5] to-white p-8 rounded-2xl shadow-xl">
						<h2 class="text-xl font-bold text-[#1A1A1A] mb-6">Envíanos un mensaje</h2>
						<form id="contact-form" name="contacto" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="space-y-5" novalidate>
							<input type="hidden" name="form-name" value="contacto" />
							<p hidden>
								<label>No filled this: <input name="bot-field" /></label>
							</p>

							<!-- Nombre -->
							<div>
								<label for="name" class="block text-sm font-medium text-[#4A4A4A] mb-2">Nombre completo *</label>
								<input
									type="text"
									id="name"
									name="name"
									placeholder="María García"
									required
									minlength="2"
									class="w-full px-4 py-3 border border-gray-200 rounded-xl text-base focus:outline-none focus:border-[#8B7355] focus:ring-2 focus:ring-[#8B7355]/20 transition-all"
								/>
								<p id="name-error" class="text-red-500 text-xs mt-1 hidden">Por favor, introduce tu nombre</p>
							</div>

							<!-- Email -->
							<div>
								<label for="email" class="block text-sm font-medium text-[#4A4A4A] mb-2">Email *</label>
								<input
									type="email"
									id="email"
									name="email"
									placeholder="maria@ejemplo.com"
									required
									class="w-full px-4 py-3 border border-gray-200 rounded-xl text-base focus:outline-none focus:border-[#8B7355] focus:ring-2 focus:ring-[#8B7355]/20 transition-all"
								/>
								<p id="email-error" class="text-red-500 text-xs mt-1 hidden">Introduce un email válido</p>
							</div>

							<!-- Teléfono -->
							<div>
								<label for="phone" class="block text-sm font-medium text-[#4A4A4A] mb-2">Teléfono</label>
								<input
									type="tel"
									id="phone"
									name="phone"
									placeholder="+34 600 000 000"
									pattern="[\+]?[0-9\s]{9,15}"
									class="w-full px-4 py-3 border border-gray-200 rounded-xl text-base focus:outline-none focus:border-[#8B7355] focus:ring-2 focus:ring-[#8B7355]/20 transition-all"
								/>
								<p id="phone-error" class="text-red-500 text-xs mt-1 hidden">Teléfono no válido</p>
							</div>

							<!-- Mensaje -->
							<div>
								<label for="message" class="block text-sm font-medium text-[#4A4A4A] mb-2">Mensaje *</label>
								<textarea
									id="message"
									name="message"
									rows="4"
									placeholder="Cuéntanos sobre tu proyecto..."
									required
									minlength="10"
									class="w-full px-4 py-3 border border-gray-200 rounded-xl text-base resize-none focus:outline-none focus:border-[#8B7355] focus:ring-2 focus:ring-[#8B7355]/20 transition-all"
								></textarea>
								<p id="message-error" class="text-red-500 text-xs mt-1 hidden">Mínimo 10 caracteres</p>
							</div>

							<!-- Documentos -->
							<div>
								<label class="block text-sm font-medium text-[#4A4A4A] mb-2">Adjuntar documentos (máx. 5MB por archivo, hasta 5 archivos)</label>
								<div id="file-drop-zone" class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center hover:border-[#8B7355] transition-colors cursor-pointer">
									<input
										type="file"
										id="files"
										name="files"
										multiple
										accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.zip,.rar"
										class="hidden"
									/>
									<div id="file-placeholder">
										<svg class="w-10 h-10 mx-auto text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
										</svg>
										<p class="text-sm text-gray-500">Haz clic o arrastra archivos aquí</p>
										<p class="text-xs text-gray-400 mt-1">PDF, DOC, JPG, PNG, ZIP (máx. 5MB cada uno)</p>
									</div>
								</div>
								<div id="file-list" class="mt-3 space-y-2"></div>
								<p id="files-error" class="text-red-500 text-xs mt-1 hidden">Error en los archivos</p>
							</div>

							<button
								type="submit"
								id="submit-btn"
								class="w-full py-4 bg-[#8B7355] text-white text-base font-semibold rounded-xl hover:bg-[#6d5a43] transition-all hover:scale-[1.02] shadow-lg flex items-center justify-center gap-2"
							>
								<span id="btn-text">Enviar mensaje</span>
								<svg id="btn-spinner" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
									<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
									<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
								</svg>
							</button>
						</form>

						<!-- Success message (hidden by default) -->
						<div id="success-message" class="hidden mt-6 p-4 bg-green-50 border border-green-200 rounded-xl text-center">
							<svg class="w-12 h-12 mx-auto text-green-500 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
							</svg>
							<h3 class="font-semibold text-green-800">¡Mensaje enviado!</h3>
							<p class="text-sm text-green-600 mt-1">Te responderemos lo antes posible.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Map -->
		<section class="py-8 px-4 bg-[#F5F5F5]">
			<div class="container">
				<div class="bg-white rounded-xl shadow-md p-6 flex flex-col sm:flex-row items-center gap-6">
					<div class="flex-shrink-0 w-56 h-56 sm:w-72 sm:h-72 rounded-lg overflow-hidden">
						<iframe
							src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3190.7548738984843!2d-6.738475923465478!3d37.30363793469282!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd0dc4a6e6e8b8f9%3A0x0!2sPlaza%20Cruces%20de%20Mayo%2C%203%2C%2021830%20Bonares%2C%20Huelva!5e0!3m2!1ses!2ses!4v1704067200000"
							width="288"
							height="288"
							style="border:0;"
							allowfullscreen
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"
						></iframe>
					</div>
					<div class="text-center sm:text-left">
						<h3 class="font-semibold text-[#1A1A1A] text-lg">Nuestra ubicación</h3>
						<p class="text-[#4A4A4A] mt-1">Plaza Cruces de Mayo 3, 21830 Bonares, Huelva</p>
						<a href="https://maps.google.com/?q=Plaza+Cruces+de+Mayo+3+Bonares+Huelva" target="_blank" rel="noopener noreferrer" class="text-[#8B7355] hover:underline mt-2 inline-block">Ver en Google Maps →</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<!-- WhatsApp fallback modal -->
	<div id="whatsapp-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
		<div class="bg-white rounded-2xl p-6 max-w-md mx-4 text-center">
			<svg class="w-16 h-16 mx-auto text-[#25D366] mb-4" fill="currentColor" viewBox="0 0 24 24">
				<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
			</svg>
			<h3 class="text-xl font-bold text-[#1A1A1A] mb-2">No se pudo enviar el mensaje</h3>
			<p class="text-[#4A4A4A] mb-6">Puedes contactarnos directamente por WhatsApp y te ayudaremos encantados.</p>
			<div class="flex flex-col gap-3">
				<a href={`${whatsappUrl}?text=${whatsappMsg}`} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 px-6 py-3 bg-[#25D366] text-white font-semibold rounded-xl hover:bg-[#20bd5a] transition-all">
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
					</svg>
					Contactar por WhatsApp
				</a>
				<button onclick="document.getElementById('whatsapp-modal').classList.add('hidden')" class="px-6 py-3 border border-gray-300 text-[#4A4A4A] font-medium rounded-xl hover:bg-gray-50 transition-all">
					Cerrar
				</button>
			</div>
		</div>
	</div>

	<Footer />
</Layout>

<script>
	const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5MB
	const MAX_FILES = 5;
	const ALLOWED_TYPES = ['application/pdf', 'application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document', 'image/jpeg', 'image/png', 'application/zip', 'application/x-rar-compressed'];
	const ALLOWED_EXTENSIONS = ['.pdf', '.doc', '.docx', '.jpg', '.jpeg', '.png', '.zip', '.rar'];

	let selectedFiles = [];

	document.addEventListener('DOMContentLoaded', () => {
		const form = document.getElementById('contact-form');
		const submitBtn = document.getElementById('submit-btn');
		const btnText = document.getElementById('btn-text');
		const btnSpinner = document.getElementById('btn-spinner');
		const successMessage = document.getElementById('success-message');
		const whatsappModal = document.getElementById('whatsapp-modal');
		const fileInput = document.getElementById('files');
		const dropZone = document.getElementById('file-drop-zone');
		const fileList = document.getElementById('file-list');
		const filePlaceholder = document.getElementById('file-placeholder');

		// Show/hide error
		const showError = (id, show) => {
			const el = document.getElementById(id);
			if (el) el.classList.toggle('hidden', !show);
		};

		// File handling
		function handleFiles(files) {
			if (!files) return;

			const newFiles = Array.from(files);
			const totalFiles = selectedFiles.length + newFiles.length;

			if (totalFiles > MAX_FILES) {
				showError('files-error', `Máximo ${MAX_FILES} archivos permitidos`);
				return;
			}

			for (const file of newFiles) {
				if (file.size > MAX_FILE_SIZE) {
					showError('files-error', `${file.name} excede 5MB`);
					return;
				}

				const ext = '.' + file.name.split('.').pop()?.toLowerCase();
				if (!ALLOWED_EXTENSIONS.includes(ext)) {
					showError('files-error', `${ext} no es un tipo permitido`);
					return;
				}

				selectedFiles.push(file);
			}

			showError('files-error', false);
			updateFileList();
		}

		function updateFileList() {
			fileList.innerHTML = '';
			if (selectedFiles.length === 0) {
				filePlaceholder.classList.remove('hidden');
			} else {
				filePlaceholder.classList.add('hidden');
			}

			selectedFiles.forEach((file, index) => {
				const div = document.createElement('div');
				div.className = 'flex items-center justify-between bg-gray-100 px-3 py-2 rounded-lg text-sm';
				div.innerHTML = `
					<span class="truncate max-w-[200px]">${file.name}</span>
					<span class="text-gray-500 text-xs ml-2">${(file.size / 1024 / 1024).toFixed(2)} MB</span>
					<button type="button" class="ml-2 text-red-500 hover:text-red-700 remove-file" data-index="${index}">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
						</svg>
					</button>
				`;
				fileList.appendChild(div);
			});

			// Remove file buttons
			document.querySelectorAll('.remove-file').forEach(btn => {
				btn.addEventListener('click', (e) => {
					const index = parseInt(e.currentTarget.dataset.index || '0');
					selectedFiles.splice(index, 1);
					updateFileList();
				});
			});
		}

		// Click to upload
		dropZone.addEventListener('click', () => fileInput.click());

		// File input change
		fileInput.addEventListener('change', () => handleFiles(fileInput.files));

		// Drag and drop
		dropZone.addEventListener('dragover', (e) => {
			e.preventDefault();
			dropZone.classList.add('border-[#8B7355]', 'bg-gray-50');
		});

		dropZone.addEventListener('dragleave', () => {
			dropZone.classList.remove('border-[#8B7355]', 'bg-gray-50');
		});

		dropZone.addEventListener('drop', (e) => {
			e.preventDefault();
			dropZone.classList.remove('border-[#8B7355]', 'bg-gray-50');
			handleFiles(e.dataTransfer?.files || null);
		});

		// Validation functions
		const validateName = (value) => value.trim().length >= 2;
		const validateEmail = (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
		const validatePhone = (value) => !value || /^[\+]?[0-9\s]{9,15}$/.test(value.replace(/\s/g, ''));
		const validateMessage = (value) => value.trim().length >= 10;
		const validateFiles = () => {
			const totalSize = selectedFiles.reduce((acc, f) => acc + f.size, 0);
			if (selectedFiles.length > MAX_FILES) return false;
			if (selectedFiles.some(f => f.size > MAX_FILE_SIZE)) return false;
			return true;
		};

		// Real-time validation
		const fields = ['name', 'email', 'phone', 'message'];
		fields.forEach(fieldId => {
			const input = document.getElementById(fieldId);
			if (input) {
				input.addEventListener('blur', () => validateField(fieldId));
				input.addEventListener('input', () => {
					if (input.classList.contains('border-red-400')) {
						validateField(fieldId);
					}
				});
			}
		});

		function validateField(fieldId) {
			const input = document.getElementById(fieldId);
			if (!input) return true;

			let isValid = true;
			const value = input.value;

			switch (fieldId) {
				case 'name':
					isValid = validateName(value);
					showError('name-error', !isValid);
					break;
				case 'email':
					isValid = validateEmail(value);
					showError('email-error', !isValid);
					break;
				case 'phone':
					if (value) {
						isValid = validatePhone(value);
						showError('phone-error', !isValid);
					}
					break;
				case 'message':
					isValid = validateMessage(value);
					showError('message-error', !isValid);
					break;
			}

			input.classList.toggle('border-red-400', !isValid);
			input.classList.toggle('border-gray-200', isValid);
			return isValid;
		}

		function validateAll() {
			let isValid = true;
			fields.forEach(fieldId => {
				if (!validateField(fieldId)) isValid = false;
			});
			if (!validateFiles()) isValid = false;
			return isValid;
		}

		// Form submit
		form.addEventListener('submit', async (e) => {
			e.preventDefault();

			if (!validateAll()) {
				return;
			}

			// Show loading
			submitBtn.disabled = true;
			btnText.textContent = 'Enviando...';
			btnSpinner.classList.remove('hidden');

			// Use fetch to submit to Netlify Forms
			const formData = new FormData(form);

			try {
				const response = await fetch('/', {
					method: 'POST',
					headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
					body: new URLSearchParams(formData).toString()
				});

				if (response.ok) {
					// Success
					form.reset();
					selectedFiles = [];
					updateFileList();
					successMessage.classList.remove('hidden');
					submitBtn.classList.add('hidden');

					// Hide success after 5 seconds
					setTimeout(() => {
						successMessage.classList.add('hidden');
						submitBtn.classList.remove('hidden');
						submitBtn.disabled = false;
						btnText.textContent = 'Enviar mensaje';
					}, 5000);
				} else {
					throw new Error('Network response not ok');
				}
			} catch (error) {
				// Show WhatsApp fallback
				whatsappModal.classList.remove('hidden');
				submitBtn.disabled = false;
				btnText.textContent = 'Enviar mensaje';
				btnSpinner.classList.add('hidden');
			}
		});
	});
</script>