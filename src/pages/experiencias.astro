---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import experienciasData from '../data/reviews.json';

const experiencias = experienciasData;
const totalResenas = experiencias.length;
const promedioEstrellas = experiencias.length > 0
    ? (experiencias.reduce((acc, r) => acc + r.estrellas, 0) / experiencias.length).toFixed(1)
    : 5;

const estadisticas = [
    { valor: promedioEstrellas, label: "Estrellas valoración", sufijo: "/5" },
    { valor: totalResenas, label: "Reseñas verificadas", sufijo: "" },
    { valor: "100%", label: "Clientes satisfechos", sufijo: "" }
];
---

<Layout title="Experiencias - MasMöbel" description="Descubre lo que dicen nuestros clientes sobre MasMöbel. Reseñas y opiniones verificadas de proyectos de cocinas y muebles.">
	<Header />

	<main class="min-h-screen flex flex-col">
		<section class="pt-20 pb-12 text-center px-4 sm:px-8" style="background: var(--color-primary); flex-shrink: 0;">
			<h1 class="text-3xl md:text-4xl font-bold text-white">Experiencias de Clientes</h1>
			<p class="text-base text-stone-300 mt-3">La satisfacción de nuestros clientes es nuestra mejor carta de presentación</p>
		</section>

		<section class="py-12 px-4 sm:px-8" style="background: var(--color-background); flex-shrink: 0;">
			<div style="max-width: 1280px; margin: 0 auto;">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
					{estadisticas.map((stat) => (
						<div class="card p-6 text-center">
							<div class="text-3xl font-bold gold-accent">{stat.valor}{stat.sufijo}</div>
							<div class="text-sm mt-1" style="color: var(--color-text-muted);">{stat.label}</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="py-16 bg-white px-4 sm:px-8" style="flex: 1;">
			<div style="max-width: 1280px; margin: 0 auto;">
				<h2 class="text-xl font-bold text-center mb-10" style="color: var(--color-text);">Lo que dicen de nosotros</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{experiencias.map((exp) => (
						<div class="card p-6 text-center">
							<div class="flex justify-center gap-1 mb-3">
								{[...Array(5)].map((_, i) => (
									<svg class={`w-5 h-5 ${i < exp.estrellas ? 'text-[#D4AF37]' : 'text-gray-300'}`} fill="currentColor" viewBox="0 0 20 20">
										<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
									</svg>
								))}
							</div>
							<p class="text-sm leading-relaxed mb-4 text-center" style="color: var(--color-text-muted);">"{exp.texto}"</p>
							<div class="border-t pt-4 text-center" style="border-color: var(--color-border);">
								<p class="font-semibold" style="color: var(--color-text);">{exp.nombre}</p>
								<p class="text-xs gold-accent">{exp.proyecto || ''} · {exp.fecha}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="py-12 px-4 sm:px-8" style="background: var(--color-primary); flex-shrink: 0;">
			<div style="max-width: 1280px; margin: 0 auto; text-align: center;">
				<h2 class="text-xl font-bold mb-4 text-white">¿Quieres compartir tu experiencia?</h2>
				<p class="text-sm text-stone-300 mb-6">Tu opinión nos ayuda a seguir mejorando y permite a otros clientes conocer nuestro trabajo.</p>
				<a href="/contacto" class="btn-primary">Contáctanos</a>
			</div>
		</section>
	</main>

	<Footer />
</Layout>