---
import { series } from '../../data/series';
import SeriePage from '../../components/SeriePage.astro';

const { slug } = Astro.params;
const serie = series.find((s) => s.slug === slug);

if (!serie) {
  return Astro.redirect('/cocinas');
}

const { name, description, price, folder, features, colorImages } = serie;
---

<SeriePage {name} {description} {price} {folder} {features} {colorImages} slug={serie.slug} />
